{
  "_type": "discord_widget_config",
  "surfaces": {
    "widget_top": {
      "layout": "widget_top_contained",
      "components": {
        "title": {
          "fields": {
            "text": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "top_title"
            }
          }
        },
        "subtitle_1": {
          "fields": {
            "text": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "top_subtitle_1"
            }
          }
        },
        "contained_image": {
          "fields": {
            "image": {
              "value_type": "data",
              "presentation_type": "image",
              "value": "top_artwork"
            }
          }
        },
        "subtitle_2": {
          "fields": {
            "text": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "top_subtitle_2"
            },
            "label": {
              "value_type": "custom_string",
              "presentation_type": "text",
              "value": "Plays"
            }
          }
        }
      }
    },
    "widget_bottom": {
      "layout": "widget_bottom_stats",
      "components": {
        "stat_1": {
          "fields": {
            "label": {
              "value_type": "custom_string",
              "presentation_type": "text",
              "value": "minutes listened"
            },
            "value": {
              "value_type": "data",
              "presentation_type": "duration",
              "value": "total_listened"
            }
          }
        },
        "stat_4": {
          "fields": {
            "value": {
              "value_type": "data",
              "presentation_type": "number",
              "value": "play_count"
            },
            "label": {
              "value_type": "custom_string",
              "presentation_type": "text",
              "value": "qualified plays"
            }
          }
        },
        "stat_2": {
          "fields": {
            "value": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "top_artist_name"
            },
            "label": {
              "value_type": "custom_string",
              "presentation_type": "text",
              "value": "most listened artist"
            }
          }
        },
        "stat_5": {
          "fields": {
            "value": {
              "value_type": "data",
              "presentation_type": "number",
              "value": "top_artist_plays"
            },
            "label": {
              "value_type": "custom_string",
              "presentation_type": "text",
              "value": "plays with that artist"
            }
          }
        },
        "stat_3": {
          "fields": {
            "value": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "top_track_name"
            },
            "label": {
              "value_type": "custom_string",
              "presentation_type": "text",
              "value": "most listened track"
            }
          }
        },
        "stat_6": {
          "fields": {
            "value": {
              "value_type": "data",
              "presentation_type": "number",
              "value": "top_track_plays"
            },
            "label": {
              "value_type": "custom_string",
              "presentation_type": "text",
              "value": "plays on that track"
            }
          }
        }
      }
    },
    "add_widget_preview": {
      "layout": "add_widget_preview_hero",
      "components": {
        "hero_image": {
          "fields": {
            "image": {
              "value_type": "application_asset",
              "presentation_type": "image",
              "value": "image"
            }
          }
        }
      }
    },
    "mini_profile": {
      "layout": "mini_profile_contained_stat",
      "components": {
        "stat": {
          "fields": {
            "text": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "mini_text"
            },
            "label": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "mini_label"
            }
          }
        },
        "contained_image": {
          "fields": {
            "image": {
              "value_type": "data",
              "presentation_type": "image",
              "value": "mini_artwork"
            }
          }
        }
      }
    },
    "activity_accessory": {
      "layout": "activity_accessory_stat",
      "components": {
        "stat": {
          "fields": {
            "text": {
              "value_type": "data",
              "presentation_type": "text",
              "value": "activity_summary",
              "fallback": {
                "value_type": "custom_string",
                "presentation_type": "text",
                "value": "View my playback stats here!"
              }
            }
          }
        }
      }
    }
  }
}
