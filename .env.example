# Provider application configuration is deliberately not included.
# Supply only values you are independently permitted to use.

TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_CLIENT_SCOPE="r_usr w_usr w_sub"

TIDAL_DEVICE_CLIENT_ID=
TIDAL_DEVICE_CLIENT_SECRET=
TIDAL_DEVICE_SCOPE="r_usr+w_usr+w_sub"

# Uncomment only when refresh uses a different permitted client pair.
# TIDAL_REFRESH_CLIENT_ID=
# TIDAL_REFRESH_CLIENT_SECRET=
TIDAL_REFRESH_SCOPE="r_usr w_usr w_sub"

# Optional overrides.
TIDAL_AUTH_BASE_URL="https://auth.tidal.com"
TIDAL_API_BASE_URL="https://openapi.tidal.com/v2/"
TIDAL_COUNTRY_CODE="US"
TIDAL_USER_AGENT="colorful/0.1"

# Optional YouTube resolver/downloader overrides.
# COLORFUL_YT_DLP=/usr/bin/yt-dlp
# COLORFUL_YT_DLP_ARGS="--cookies-from-browser firefox"
