<Window
    x:Class="Colorful.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="colorful">

    <Grid Background="{StaticResource AppBackgroundBrush}" FontFamily="{StaticResource ColorfulFont}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="78" />
        </Grid.RowDefinitions>

        <Grid x:Name="TitleBarDragRegion" Grid.Row="0" Padding="12,0,150,0" Background="#101014">
            <Grid.RowDefinitions>
                <RowDefinition Height="2" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource AccentBrush}" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Image Source="Assets/colorful.svg" Width="14" Height="14" />
                <TextBlock Text="colorful" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0A0A0D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <StackPanel VerticalAlignment="Top">
                        <Button Style="{StaticResource SquareButtonStyle}" Width="56" Height="52" BorderThickness="0,0,0,1">
                            <SymbolIcon Symbol="Home" />
                        </Button>
                        <Button Style="{StaticResource SquareButtonStyle}" Width="56" Height="52" BorderThickness="0,0,0,1">
                            <SymbolIcon Symbol="Library" />
                        </Button>
                        <Button Style="{StaticResource SquareButtonStyle}" Width="56" Height="52" BorderThickness="0,0,0,1">
                            <SymbolIcon Symbol="Download" />
                        </Button>
                    </StackPanel>
                    <Button Style="{StaticResource SquareButtonStyle}" Width="56" Height="52" BorderThickness="0,1,0,0" VerticalAlignment="Bottom">
                        <SymbolIcon Symbol="Setting" />
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="26,22,26,28" Spacing="22">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Windows, in color." FontSize="30" FontWeight="Light" />
                        <TextBlock Text="The native shell is connected to the same local library engine." Foreground="{StaticResource MutedBrush}" FontSize="13" />
                    </StackPanel>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Library" FontSize="18" FontWeight="SemiBold" />
                                <Border Height="148" Background="#0A0A0D" BorderBrush="#202026" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
                                        <SymbolIcon Symbol="Library" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="Your local library is ready" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                        <TextBlock Text="Provider adapters are the next Windows layer." Foreground="{StaticResource MutedBrush}" FontSize="12" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{StaticResource RaisedPanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Engine" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock x:Name="CoreStatusText" Text="Opening…" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                <TextBlock x:Name="CoreDetailsText" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="#08080A" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Padding="14,9">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="48" Height="48" Background="{StaticResource RaisedPanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Image Source="Assets/colorful.svg" Width="28" Height="28" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Nothing playing" FontWeight="SemiBold" />
                        <TextBlock Text="Choose a track" Foreground="{StaticResource MutedBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                        <Button Style="{StaticResource SquareButtonStyle}" Width="34" Height="30" IsEnabled="False">
                            <SymbolIcon Symbol="Back" />
                        </Button>
                        <Button x:Name="PlayPauseButton" Style="{StaticResource SquareButtonStyle}" Width="42" Height="34" Click="PlayPauseButton_Click">
                            <SymbolIcon x:Name="PlayPauseIcon" Symbol="Play" />
                        </Button>
                        <Button Style="{StaticResource SquareButtonStyle}" Width="34" Height="30" IsEnabled="False">
                            <SymbolIcon Symbol="Forward" />
                        </Button>
                    </StackPanel>
                    <Grid Width="420">
                        <Slider x:Name="PositionSlider" Minimum="0" Maximum="1" Value="0" IsEnabled="False" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                    <SymbolIcon Symbol="Volume" Foreground="{StaticResource MutedBrush}" />
                    <Slider x:Name="VolumeSlider" Width="105" Minimum="0" Maximum="1" Value="0.7" ValueChanged="VolumeSlider_ValueChanged" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
