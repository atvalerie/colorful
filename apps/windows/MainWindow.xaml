<Window
    x:Class="Colorful.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="colorful">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="88" />
        </Grid.RowDefinitions>

        <!-- Native caption buttons remain at the right; everything else is our compact title bar. -->
        <Grid x:Name="TitleBarDragRegion" Grid.Row="0" Background="#17171B">
            <Grid.RowDefinitions>
                <RowDefinition Height="2" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource AccentBrush}" />
            <StackPanel Grid.Row="1" Margin="10,0,150,0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <Image Source="Assets/colorful.svg" Width="15" Height="15" />
                <TextBlock Text="colorful" FontSize="10" FontWeight="SemiBold" Foreground="#B8B3C0" VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#09090C" BorderBrush="#292930" BorderThickness="0,0,1,0">
                <Grid Margin="0,14">
                    <StackPanel Spacing="7" HorizontalAlignment="Center">
                        <Grid Width="44" Height="44">
                            <Border Width="3" Height="26" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left" />
                            <Button Style="{StaticResource NavButtonStyle}" ToolTipService.ToolTip="Search">
                                <Image Source="Assets/icons/home.svg" Width="22" Height="22" />
                            </Button>
                        </Grid>
                        <Button Style="{StaticResource NavButtonStyle}" ToolTipService.ToolTip="Library">
                            <Image Source="Assets/icons/library.svg" Width="21" Height="21" Opacity="0.7" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" ToolTipService.ToolTip="Settings">
                            <Image Source="Assets/icons/settings.svg" Width="21" Height="21" Opacity="0.7" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" ToolTipService.ToolTip="Offline music">
                            <Image Source="Assets/icons/download.svg" Width="21" Height="21" Opacity="0.7" />
                        </Button>
                    </StackPanel>

                    <StackPanel Spacing="7" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                        <Button Style="{StaticResource NavButtonStyle}" ToolTipService.ToolTip="YouTube Music">
                            <Image Source="Assets/icons/youtube.svg" Width="21" Height="21" Opacity="0.66" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" ToolTipService.ToolTip="SoundCloud">
                            <Image Source="Assets/icons/soundcloud.svg" Width="22" Height="22" Opacity="0.66" />
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" ToolTipService.ToolTip="TIDAL">
                            <Image Source="Assets/icons/tidal.svg" Width="21" Height="21" Opacity="0.66" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0C0C10" BorderBrush="#292930" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="520" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="82" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Height="40" VerticalAlignment="Center">
                            <TextBox
                                x:Name="SearchBox"
                                Padding="40,8,12,0"
                                Background="#07070A"
                                BorderBrush="#303038"
                                BorderThickness="1"
                                CornerRadius="0"
                                FontFamily="{StaticResource ColorfulFont}"
                                FontSize="13"
                                VerticalContentAlignment="Center"
                                PlaceholderText="Search tracks, albums, artists" />
                            <Image Source="Assets/icons/search.svg" Width="17" Height="17" Margin="13,0,0,0" Opacity="0.45" HorizontalAlignment="Left" IsHitTestVisible="False" />
                        </Grid>
                        <Button Grid.Column="2" Height="40" Style="{StaticResource SearchButtonStyle}" Content="Search" FontFamily="{StaticResource ColorfulFont}" FontSize="12" FontWeight="SemiBold" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="28,23,28,18">
                    <StackPanel>
                        <TextBlock Text="Search" FontSize="24" FontWeight="Bold" />
                        <StackPanel Margin="0,92,0,0" HorizontalAlignment="Center" Spacing="7">
                            <Image Source="Assets/icons/music.svg" Width="28" Height="28" Opacity="0.24" />
                            <TextBlock Text="Find something to play" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="Search across your connected music services" FontSize="12" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#070709" BorderBrush="#2B2B32" BorderThickness="0,1,0,0">
            <Grid Margin="16,0" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="50" Height="50" Background="#141418" BorderBrush="#292930" BorderThickness="1">
                        <Image Source="Assets/icons/music.svg" Width="20" Height="20" Opacity="0.28" />
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Nothing playing" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="Choose a track" FontSize="11" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1" MaxWidth="560" MinWidth="310" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="22" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="7" HorizontalAlignment="Center">
                        <Button Style="{StaticResource PlayerButtonStyle}" ToolTipService.ToolTip="Shuffle">
                            <Image Source="Assets/icons/shuffle.svg" Width="17" Height="17" Opacity="0.45" />
                        </Button>
                        <Button Style="{StaticResource PlayerButtonStyle}" Width="36" Height="36" ToolTipService.ToolTip="Previous">
                            <Image Source="Assets/icons/previous.svg" Width="19" Height="19" Opacity="0.65" />
                        </Button>
                        <Button x:Name="PlayPauseButton" Style="{StaticResource AccentButtonStyle}" Width="42" Height="42" Click="PlayPauseButton_Click" ToolTipService.ToolTip="Play">
                            <Image x:Name="PlayPauseImage" Source="Assets/icons/play-dark.svg" Width="19" Height="19" />
                        </Button>
                        <Button Style="{StaticResource PlayerButtonStyle}" Width="36" Height="36" ToolTipService.ToolTip="Next">
                            <Image Source="Assets/icons/next.svg" Width="19" Height="19" Opacity="0.65" />
                        </Button>
                        <Button Style="{StaticResource PlayerButtonStyle}" ToolTipService.ToolTip="Repeat">
                            <Image Source="Assets/icons/repeat.svg" Width="17" Height="17" Opacity="0.45" />
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="1" ColumnSpacing="8" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="0:00" FontSize="10" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                        <Grid Grid.Column="1" Height="16">
                            <Border Height="4" Background="#29292F" VerticalAlignment="Center" />
                            <Border Width="0" Height="4" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Grid.Column="2" Text="0:00" FontSize="10" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource PlayerButtonStyle}" Width="32" Height="32" ToolTipService.ToolTip="Mute">
                        <Image Source="Assets/icons/volume.svg" Width="18" Height="18" Opacity="0.58" />
                    </Button>
                    <Grid x:Name="VolumeTrack" Width="90" Height="28" SizeChanged="VolumeTrack_SizeChanged">
                        <Border Height="4" Background="#2A2A30" VerticalAlignment="Center" />
                        <Border x:Name="VolumeFill" Height="4" Background="{StaticResource AccentBrush}" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <Ellipse x:Name="VolumeThumb" Width="9" Height="9" Fill="#FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" />
                        <Slider x:Name="VolumeSlider" Minimum="0" Maximum="1" Value="0.7" Opacity="0" ValueChanged="VolumeSlider_ValueChanged" />
                    </Grid>
                    <Button Style="{StaticResource PlayerButtonStyle}" Width="36" Height="36" ToolTipService.ToolTip="Lyrics">
                        <Image Source="Assets/icons/lyrics.svg" Width="19" Height="19" Opacity="0.52" />
                    </Button>
                    <Button Style="{StaticResource PlayerButtonStyle}" Width="40" Height="40" ToolTipService.ToolTip="Queue">
                        <Image Source="Assets/icons/queue.svg" Width="20" Height="20" Opacity="0.62" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
